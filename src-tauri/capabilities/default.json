{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the desktop shell windows",
  "windows": ["main", "setup-wizard", "settings", "about"],
  "permissions": [
    "core:default",
    "dialog:default",
    "core:event:default",
    "core:window:default",
    "core:window:allow-close",
    "core:window:allow-destroy",
    "core:window:allow-minimize",
    "core:window:allow-toggle-maximize",
    "core:window:allow-start-dragging",
    "opener:default"
  ]
}
