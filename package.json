{
  "name": "@board-enthusiasts/be-home-for-desktop",
  "private": true,
  "version": "0.1.0",
  "description": "Board Enthusiasts desktop utility shell for guided Board installs.",
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1 --port 1420",
    "build": "tsc --project tsconfig.json && vite build",
    "preview": "vite preview --host 127.0.0.1 --port 4174",
    "typecheck": "tsc --project tsconfig.json",
    "test:renderer": "vitest run --config vitest.config.ts",
    "test:host": "cargo test --manifest-path src-tauri/Cargo.toml",
    "test": "npm run test:renderer && npm run test:host",
    "tauri": "tauri"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/plugin-dialog": "^2.7.0",
    "@tauri-apps/plugin-opener": "^2.5.3",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.1",
    "@tauri-apps/cli": "^2.10.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^5.0.0",
    "jsdom": "^26.1.0",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.8.3",
    "vite": "^7.0.4",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
